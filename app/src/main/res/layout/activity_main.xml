<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117">

    <!-- App Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DETECTOR"
        android:textColor="#E0E0E0"
        android:textSize="22sp"
        android:letterSpacing="0.15"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"/>

    <!-- Status Pill -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to scan"
        android:textColor="#4CAF50"
        android:textSize="12sp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_status_pill"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Scan Button -->
    <Button
        android:id="@+id/btnScan"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="SCAN"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="#0D2137"
        android:strokeColor="#2979FF"
        app:strokeWidth="3dp"
        app:cornerRadius="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    <!-- Bottom Bar -->
    <View
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E2433"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="80dp"/>

    <!-- Info Button -->
    <Button
        android:id="@+id/btnInfo"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="124dp"
        android:layout_height="104dp"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#1A1F2E"
        android:text="info"
        android:textColor="#90CAF9"
        android:textSize="22sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#444444"
        app:strokeWidth="1.5dp" />

    <!-- Exit Button -->
    <Button
        android:id="@+id/btnExit"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="127dp"
        android:layout_height="107dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#1A1F2E"
        android:text="Exit"
        android:textColor="#EF5350"
        android:textSize="20sp"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeColor="#444444"
        app:strokeWidth="1.5dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
